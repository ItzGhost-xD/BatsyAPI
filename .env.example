# ── Discord ──────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# ── Server ────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
API_BASE_URL=http://localhost:3000

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TTL=300              # seconds — presence cache lifetime
REDIS_USER_TTL=3600        # seconds — user-profile cache lifetime

# ── MongoDB ───────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/discord_presence
MONGODB_DB=discord_presence

# ── Rate Limiting ─────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
WS_RATE_LIMIT_MAX=10       # max WS connections per IP

# ── Caching ───────────────────────────────────────────────────────────
ETAG_SECRET=change_me_to_something_random_and_long

# ── Auth (optional API key gate) ──────────────────────────────────────
API_KEY_REQUIRED=false
API_KEYS=key1,key2,key3

# ── Horizontal Sharding ───────────────────────────────────────────────
SHARD_COUNT=1              # bump when scaling
SHARD_ID=0

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Auto-deploy webhook ────────────────────────────────────────────────
# Set this to any random string, then add the same value as the
# "Secret" field when creating the webhook on GitHub.
DEPLOY_SECRET=generate_with_node_crypto
DEPLOY_BRANCH=main
